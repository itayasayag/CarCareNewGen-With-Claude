# ============================================================
#  CarCare — local development environment variables
#  Copy this file to .env and fill in your values.
#  The .env file is gitignored and never committed.
# ============================================================

# ── Database (local SQL Server Express) ──────────────────────
# Use these for local development (Windows Auth or SQL Auth).
DB_SERVER=L1000124986\SQLEXPRESS
DB_NAME=CarCare
DB_USER=
DB_PASSWORD=

# ── OR: use a full connection string (Azure SQL / Railway) ───
# Leave DATABASE_URL blank for local dev.
# Fill it in when deploying to Railway or any cloud host.
# Example for Azure SQL:
# DATABASE_URL=DRIVER={ODBC Driver 18 for SQL Server};SERVER=yourserver.database.windows.net;DATABASE=CarCare;UID=youruser;PWD=yourpass;Encrypt=yes;TrustServerCertificate=no
DATABASE_URL=

# ── Email (for reminders) ─────────────────────────────────────
EMAIL_ADDRESS=carcarereminders@gmail.com
EMAIL_PASSWORD=

# ── File uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploadedFiles
